.tab-bar {
  display: flex; height: 88rpx; background: #fff; border-top: 1rpx solid #F0F0F0;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #999;
}
.tab-item.active { color: #E10600; font-weight: 600; }
