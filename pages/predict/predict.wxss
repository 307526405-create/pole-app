.page{background:#F5F5F5;min-height:100vh}
.nav-bar{display:flex;align-items:center;height:88rpx;padding:0 32rpx}
.back{font-size:36rpx;color:#333;margin-right:16rpx}
.nav-title{font-size:32rpx;font-weight:600;color:#333}

.step-bar{text-align:center;padding:20rpx 32rpx}
.step-title{font-size:30rpx;font-weight:600;color:#1a1a1a}

.step-dots{display:flex;justify-content:center;gap:12rpx;padding:0 0 16rpx}
.dot{width:12rpx;height:12rpx;border-radius:6rpx;background:#E0E0E0}
.dot.done{background:#E10600}

.driver-grid{display:flex;flex-wrap:wrap;padding:0 20rpx;gap:8rpx;justify-content:center}
.dc{width:calc(33.33% - 8rpx);background:#fff;border-radius:8rpx;padding:16rpx 8rpx;text-align:center;box-sizing:border-box;box-shadow:0 1rpx 4rpx rgba(0,0,0,.03)}
.dc.sel{background:#FFF0F0;border:2rpx solid #E10600;padding:14rpx 6rpx}
.dc-n{font-size:22rpx;color:#E10600;font-weight:700;display:block}
.dc-nm{font-size:22rpx;font-weight:600;color:#333;display:block;margin-top:4rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.option-grid{display:flex;flex-direction:column;padding:0 32rpx;gap:16rpx;margin-top:16rpx}
.oc{background:#fff;border-radius:12rpx;padding:36rpx;text-align:center;font-size:28rpx;font-weight:600;color:#333;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.oc.sel{background:#FFF0F0;border:2rpx solid #E10600;color:#E10600}

.nav-btns{display:flex;gap:16rpx;padding:24rpx 32rpx}
.nb{flex:1;height:80rpx;border:none;border-radius:12rpx;font-size:28rpx;font-weight:600;display:flex;align-items:center;justify-content:center}
.nb.prev{background:#F5F5F5;color:#666}
.nb.next{background:#E10600;color:#fff}
button::after{border:none}

.celebrate{text-align:center;padding:200rpx 32rpx 0}
.cel-icon{font-size:120rpx;display:block;animation:bounce .6s}
.cel-text{font-size:36rpx;font-weight:700;color:#333;display:block;margin-top:24rpx}
.cel-sub{font-size:28rpx;color:#E10600;font-weight:600;display:block;margin-top:12rpx}
@keyframes bounce{0%,100%{transform:scale(1)}50%{transform:scale(1.2)}}
