.page { background:#F5F5F5; min-height:100vh; padding-bottom:120rpx; }
.nav-bar { display:flex; align-items:center; height:88rpx; padding:0 32rpx; }
.back { font-size:36rpx; color:#333; margin-right:16rpx; }
.nav-title { font-size:32rpx; font-weight:600; color:#333; }

.step-indicator { text-align:center; padding:24rpx 32rpx 0; }
.step-q { font-size:32rpx; font-weight:700; color:#1a1a1a; display:block; }
.step-sub { font-size:22rpx; color:#999; display:block; margin-top:6rpx; }

.step-dots { display:flex; justify-content:center; gap:16rpx; padding:20rpx 0; }
.dot { width:14rpx; height:14rpx; border-radius:7rpx; background:#E0E0E0; }
.dot.done { background:#E10600; }

.driver-grid { display:flex; flex-wrap:wrap; padding:0 24rpx; gap:12rpx; }
.driver-card { width:calc(33.33% - 8rpx); background:#fff; border-radius:12rpx; padding:24rpx 12rpx; text-align:center; box-sizing:border-box; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.04); }
.driver-card.sel { background:#FFF0F0; border:2rpx solid #E10600; }
.dc-num { font-size:24rpx; color:#E10600; font-weight:700; display:block; }
.dc-name { font-size:24rpx; font-weight:600; color:#333; display:block; margin-top:6rpx; }
.dc-team { font-size:20rpx; color:#999; display:block; margin-top:2rpx; }

.option-grid { display:flex; flex-direction:column; padding:0 32rpx; gap:16rpx; margin-top:24rpx; }
.option-card { background:#fff; border-radius:12rpx; padding:32rpx; text-align:center; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.04); }
.option-card.sel { background:#FFF0F0; border:2rpx solid #E10600; }
.oc-text { font-size:28rpx; font-weight:600; color:#333; }

.submit-area { padding:32rpx; }
.submit-btn { width:100%; height:96rpx; background:#E10600; color:#fff; border:none; border-radius:16rpx; font-size:32rpx; font-weight:700; }
button::after { border:none; }

.celebrate { text-align:center; padding:200rpx 32rpx 0; }
.cel-icon { font-size:120rpx; display:block; animation:bounce .6s ease; }
.cel-text { font-size:36rpx; font-weight:700; color:#333; display:block; margin-top:24rpx; }
.cel-sub { font-size:28rpx; color:#E10600; font-weight:600; display:block; margin-top:12rpx; }
@keyframes bounce { 0%,100%{transform:scale(1)}50%{transform:scale(1.2)} }
