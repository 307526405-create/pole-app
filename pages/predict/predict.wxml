<view class="page">
  <view class="nav-bar">
    <text class="back" bind:tap="onBack">←</text>
    <text class="nav-title">竞猜</text>
  </view>

  <view wx:if="{{!showCelebrate}}">
    <view class="step-bar">
      <text class="step-title">{{stepTitles[step]}}</text>
    </view>

    <view class="step-dots">
      <view class="dot {{step>=0?'done':''}}"></view>
      <view class="dot {{step>=1?'done':''}}"></view>
      <view class="dot {{step>=2?'done':''}}"></view>
      <view class="dot {{step>=3?'done':''}}"></view>
      <view class="dot {{step>=4?'done':''}}"></view>
      <view class="dot {{step>=5?'done':''}}"></view>
    </view>

    <view class="driver-grid" wx:if="{{step<=3}}">
      <view wx:for="{{drivers}}" wx:key="num" class="dc {{item.selected?'sel':''}}" bind:tap="selectDriver" data-idx="{{index}}">
        <text class="dc-n">#{{item.num}}</text>
        <text class="dc-nm">{{item.name}}</text>
      </view>
    </view>

    <view class="option-grid" wx:if="{{step>=4}}">
      <view wx:for="{{options}}" wx:key="text" class="oc {{item.sel?'sel':''}}" bind:tap="selectOption" data-idx="{{index}}">
        <text>{{item.text}}</text>
      </view>
    </view>

    <view class="nav-btns">
      <button class="nb prev" bind:tap="prevStep" wx:if="{{step>0}}">上一题</button>
      <button class="nb next" bind:tap="nextStep" wx:if="{{canNext}}">{{step===5?'提交':'下一题'}}</button>
    </view>
  </view>

  <view class="celebrate" wx:if="{{showCelebrate}}">
    <text class="cel-icon">🎉</text>
    <text class="cel-text">预测已提交</text>
    <text class="cel-sub">最高可得 38 分</text>
  </view>
</view>
