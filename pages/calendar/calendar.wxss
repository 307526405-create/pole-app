.page { padding: 0 32rpx 120rpx; }
.nav-bar { display: flex; justify-content: space-between; align-items: center; height: 88rpx; }
.nav-title { font-size: 36rpx; font-weight: 600; color: #333; }
.tabs { display: flex; gap: 0; margin-bottom: 16rpx; background: #fff; border-radius: 8rpx; padding: 4rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 24rpx; color: #999; font-weight: 600; border-radius: 6rpx; }
.tab.active { background: #F5F5F5; color: #E10600; }
.cal-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #F0F0F0; gap: 16rpx; }
.cal-flag { font-size: 36rpx; width: 48rpx; text-align: center; }
.cal-info { flex: 1; }
.cal-gp { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.cal-detail { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.cal-tag { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 8rpx; font-weight: 600; }
.cal-tag.done { background: #F5F5F5; color: #999; }
.cal-tag.now { background: #E10600; color: #fff; }
.cal-tag.next { background: rgba(225,6,0,0.06); color: #E10600; }
.ds-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; gap: 12rpx; }
.ds-pos { width: 36rpx; font-size: 28rpx; font-weight: 600; color: #999; text-align: center; }
.ds-row:nth-child(1) .ds-pos,.ds-row:nth-child(2) .ds-pos,.ds-row:nth-child(3) .ds-pos { color: #FFC107; }
.ds-img { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; }
.ds-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 18rpx; font-weight: 700; color: #fff; }
.ds-info { flex: 1; }
.ds-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.ds-en { font-size: 20rpx; color: #999; display: block; }
.ds-pts { font-size: 28rpx; font-weight: 600; color: #333; }
