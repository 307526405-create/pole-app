<view class="page">
  <view class="nav-bar"><text class="nav-title">赛程</text></view>
  <view class="tabs">
    <text class="tab {{subtab==0?'active':''}}" bind:tap="switchSub" data-idx="0">赛程</text>
    <text class="tab {{subtab==1?'active':''}}" bind:tap="switchSub" data-idx="1">车手</text>
    <text class="tab {{subtab==2?'active':''}}" bind:tap="switchSub" data-idx="2">车队</text>
  </view>
  <view wx:if="{{subtab==0}}">
    <view wx:for="{{races}}" wx:key="round" class="cal-row">
      <text class="cal-flag">{{item.flag}}</text>
      <view class="cal-info"><text class="cal-gp">{{item.gp}}</text><text class="cal-detail">{{item.date}} · {{item.circuit}}</text></view>
      <text class="cal-tag {{item.status}}">{{item.tag}}</text>
    </view>
  </view>
  <view wx:if="{{subtab>0}}">
    <view wx:for="{{standings[subtab-1]}}" wx:key="pos" class="ds-row">
      <text class="ds-pos">{{item.pos}}</text>
      <image wx:if="{{item.img}}" class="ds-img" src="{{item.img}}" mode="aspectFill" binderror="onImgErr" data-idx="{{index}}" data-tab="{{subtab}}"/>
      <view wx:else class="ds-avatar" style="background:#E10600"><text>{{item.en}}</text></view>
      <view class="ds-info"><text class="ds-name">{{item.name}}</text><text class="ds-en">{{item.en}}</text></view>
      <text class="ds-pts">{{item.pts}}</text>
    </view>
  </view>
</view>
