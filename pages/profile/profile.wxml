<view class="page">
  <view class="header">
    <view class="avatar">🏎️</view>
    <text class="name">车迷·老李</text>
    <text class="sub">加入2赛季 · 🔥 连续预测9站</text>
    <view class="mini-stats">
      <view class="ms"><text class="ms-v">156</text><text class="ms-l">积分</text></view>
      <view class="ms"><text class="ms-v">42</text><text class="ms-l">排名</text></view>
      <view class="ms"><text class="ms-v green">47%</text><text class="ms-l">准确率</text></view>
    </view>
  </view>

  <view class="section-title">竞猜历史</view>
  <view class="card">
    <view wx:for="{{history}}" wx:key="race" class="h-row">
      <text class="h-race">{{item.race}}</text>
      <text class="h-detail">{{item.detail}}</text>
      <text class="h-score">{{item.score}}</text>
    </view>
    <view wx:if="{{history.length === 0}}" class="empty">暂无竞猜记录</view>
  </view>

  <view class="section-title">更多</view>
  <view class="card">
    <view class="menu-row" bind:tap="onPro">
      <text class="menu-text">杆位 Pro</text>
      <text class="menu-sub">圈速对比 · 历史数据 · 无广告</text>
      <text class="menu-arrow">¥18/月</text>
    </view>
    <view class="menu-row">
      <text class="menu-text">赛季报告</text>
      <text class="menu-sub">赛季结束后自动生成</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>
</view>
