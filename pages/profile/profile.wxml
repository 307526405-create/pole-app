<view class="page">
  <view class="header">
    <view class="avt"><text>老李</text></view>
    <text class="nick">车迷·老李</text>
    <text class="sub">加入2赛季 · 连续预测9站</text>
  </view>

  <view class="stat-card">
    <view class="sc-item">
      <text class="sc-v">156</text>
      <text class="sc-l">赛季积分</text>
    </view>
    <view class="sc-div"></view>
    <view class="sc-item">
      <text class="sc-v">42</text>
      <text class="sc-l">排名</text>
    </view>
    <view class="sc-div"></view>
    <view class="sc-item">
      <text class="sc-v green">47%</text>
      <text class="sc-l">准确率</text>
    </view>
  </view>

  <view class="card">
    <view class="card-hd">我支持的车队与车手</view>
    <view class="fav-row">
      <view class="fav ferrari" bind:tap="pickTeam">
        <image class="fav-logo" src="{{favTeamLogo}}" mode="aspectFit" lazy-load="true"/>
        <text class="fav-name">{{favTeamName}}</text>
      </view>
      <view class="fav" bind:tap="pickDriver">
        <image class="fav-avatar" src="{{favDriverImg}}" mode="aspectFill" lazy-load="true"/>
        <text class="fav-name">{{favDriverName}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showPick}}" class="modal-mask" bind:tap="doPick">
    <view class="modal-box" catchtap="">
      <text class="modal-title">{{pickTitle}}</text>
      <view class="modal-grid">
        <view wx:for="{{pickItems}}" wx:key="*this" class="modal-item" bind:tap="doPick" data-idx="{{index}}">{{item}}</view>
      </view>
      <text class="modal-cancel" bind:tap="doPick">取消</text>
    </view>
  </view>

  <view class="card">
    <view class="card-hd">最近预测</view>
    <view wx:for="{{history}}" wx:key="race" class="h-row">
      <text class="h-l">{{item.race}}</text>
      <view class="h-m"><text wx:for="{{item.items}}" wx:key="*this" class="h-tag {{item.cls}}">{{item.txt}}</text></view>
      <text class="h-r">+{{item.score}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-hd">2026 赛季报告</view>
    <view class="report"><text class="rp-t">赛季结束后自动生成</text><text class="rp-s">可分享到朋友圈</text></view>
  </view>

  
  <view wx:if="{{compResult}}" class="card" hidden>
    <view class="card-hd">对比结果</view>
    <view class="comp-row"><text class="comp-label">积分</text><text class="comp-v1">{{compResult.d1pts}}</text><text class="comp-v2">{{compResult.d2pts}}</text></view>
    <view class="comp-row"><text class="comp-label">分站冠军</text><text class="comp-v1">{{compResult.d1wins}}</text><text class="comp-v2">{{compResult.d2wins}}</text></view>
    <view class="comp-row"><text class="comp-label">排名</text><text class="comp-v1">P{{compResult.d1pos}}</text><text class="comp-v2">P{{compResult.d2pos}}</text></view>
  </view>

  <view wx:if="{{compareList}}" class="card">
    <view class="card-hd">车手对比</view>
    <scroll-view scroll-x enable-flex style="white-space:nowrap">
      <view style="display:inline-flex;gap:0">
        <view style="width:160rpx;flex-shrink:0">
          <view class="ch-th" style="height:80rpx"></view>
          <view class="ch-row">排名</view>
          <view class="ch-row">积分</view>
          <view class="ch-row">分站冠军</view>
        </view>
        <view wx:for="{{compareList}}" wx:key="name" style="width:200rpx;flex-shrink:0;text-align:center;border-left:2rpx solid #F0F0F0">
          <view class="ch-th"><text style="font-size:24rpx;font-weight:700;color:#333">{{item.name}}</text></view>
          <view class="ch-row" style="font-family:monospace">{{item.position}}</view>
          <view class="ch-row" style="font-family:monospace;font-weight:700">{{item.points}}</view>
          <view class="ch-row" style="font-family:monospace">{{item.wins}}</view>
        </view>
      </view>
    </scroll-view>
    <button class="pro-btn" bind:tap="goCompare" hover-class="none" style="margin-top:16rpx">更换车手</button>
  </view>
<view class="pro">
    <view class="pro-l"><text class="pro-t">Pro 功能</text><text class="pro-s">圈速数据对比 · 历史回溯 · 免广告</text></view>
    <button class="pro-btn" bind:tap="goCompare" hover-class="none">车手对比</button>
  </view>
</view>
<view class="footer" style="text-align:center;padding:32rpx 0;">
  <text class="footer-text" bind:tap="goPrivacy">隐私政策</text>
</view>
