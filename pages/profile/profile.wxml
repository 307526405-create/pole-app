<view class="page">
  <view class="header">
    <view class="avt"><text>老李</text></view>
    <text class="nick">车迷·老李</text>
    <view class="streak-badge">🔥 连续预测 9 站</view>
  </view>

  <view class="stats">
    <view class="st"><text class="st-v">156</text><text class="st-l">赛季积分</text></view>
    <view class="st"><text class="st-v">42</text><text class="st-l">排名</text></view>
    <view class="st"><text class="st-v green">47%</text><text class="st-l">准确率</text></view>
  </view>

  <view class="card">
    <view class="card-hd">我支持的车队与车手</view>
    <view class="fav-row">
      <view class="fav ferrari" bind:tap="pickTeam">
        <image class="fav-logo" src="{{favTeamLogo}}" mode="aspectFit"/>
        <text class="fav-name">{{favTeamName}}</text>
      </view>
      <view class="fav" bind:tap="pickDriver">
        <image class="fav-avatar" src="{{favDriverImg}}" mode="aspectFill"/>
        <text class="fav-name">{{favDriverName}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showPick}}" class="modal-mask" bind:tap="doPick">
    <view class="modal-box" catchtap="">
      <text class="modal-title">{{pickTitle}}</text>
      <view class="modal-grid">
        <view wx:for="{{pickItems}}" wx:key="*this" class="modal-item" bind:tap="doPick" data-idx="{{index}}">{{item}}</view>
      </view>
      <text class="modal-cancel" bind:tap="doPick">取消</text>
    </view>
  </view>

  <view class="card">
    <view class="card-hd">最近预测</view>
    <view wx:for="{{history}}" wx:key="race" class="h-row">
      <text class="h-l">{{item.race}}</text>
      <view class="h-m"><text wx:for="{{item.items}}" wx:key="*this" class="h-tag {{item.cls}}">{{item.txt}}</text></view>
      <text class="h-r">+{{item.score}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-hd">2026 赛季报告</view>
    <view class="report"><text class="rp-t">赛季结束后自动生成</text><text class="rp-s">可分享到朋友圈</text></view>
  </view>

  <view class="pro">
    <view class="pro-l"><text class="pro-t">Pro 功能</text><text class="pro-s">圈速数据对比 · 历史回溯 · 免广告</text></view>
    <text class="pro-btn">免费试用</text>
  </view>
</view>
<view class="footer" style="text-align:center;padding:32rpx 0;">
  <text class="footer-text" bind:tap="goPrivacy">隐私政策</text>
</view>
