.page { padding: 0 32rpx 120rpx; background: #F5F5F5; min-height: 100vh; }

.header { text-align: center; padding: 48rpx 0 32rpx; }
.avatar { width: 88rpx; height: 88rpx; background: #E10600; border-radius: 44rpx; margin: 0 auto 12rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.name { font-size: 32rpx; font-weight: 600; color: #333; display: block; }
.sub { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.mini-stats { display: flex; justify-content: center; gap: 24rpx; margin-top: 24rpx; }
.ms { text-align: center; }
.ms-v { font-size: 40rpx; font-weight: 700; color: #333; display: block; font-family: monospace; }
.ms-v.green { color: #52C41A; }
.ms-l { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }

.section-title { font-size: 22rpx; color: #999; font-weight: 600; margin: 24rpx 0 12rpx; }

.card { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }

.h-row { display: flex; align-items: center; padding: 20rpx 32rpx; border-bottom: 1rpx solid #F5F5F5; }
.h-row:last-child { border-bottom: none; }
.h-race { font-size: 24rpx; color: #999; width: 140rpx; }
.h-detail { font-size: 22rpx; color: #666; flex: 1; }
.h-score { font-size: 28rpx; font-weight: 700; color: #52C41A; font-family: monospace; }
.empty { text-align: center; padding: 48rpx 0; font-size: 24rpx; color: #999; }

.menu-row { display: flex; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid #F5F5F5; }
.menu-row:last-child { border-bottom: none; }
.menu-text { font-size: 28rpx; font-weight: 600; color: #333; }
.menu-sub { flex: 1; font-size: 22rpx; color: #999; margin-left: 16rpx; }
.menu-arrow { font-size: 22rpx; color: #E10600; font-weight: 600; }
