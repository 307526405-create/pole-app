.page{padding:0 32rpx 120rpx;background:#F5F5F5;min-height:100vh}

.header{text-align:center;padding:48rpx 0 20rpx}
.avt{width:72rpx;height:72rpx;background:#E10600;border-radius:36rpx;margin:0 auto 12rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx;font-weight:700;color:#fff}
.nick{font-size:32rpx;font-weight:700;color:#1a1a1a;display:block}
.sub{font-size:22rpx;color:#999;display:block;margin-top:4rpx}

/* 卡片堆叠风格——积分行 */
.stat-card{display:flex;background:#fff;border-radius:18rpx;padding:8rpx 0;margin-bottom:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}
.sc-item{flex:1;text-align:center;padding:24rpx 0}
.sc-v{font-size:40rpx;font-weight:800;font-family:monospace;color:#1a1a1a;display:block}
.sc-v.green{color:#52C41A}
.sc-l{font-size:20rpx;color:#999;display:block;margin-top:4rpx}
.sc-div{width:1rpx;background:#F0F0F0;margin:20rpx 0}

/* 小红书风卡片 */
.card{background:#fff;border-radius:20rpx;padding:28rpx;margin-bottom:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.card-hd{font-size:28rpx;font-weight:600;color:#1a1a1a;margin-bottom:20rpx}
.streak-badge{display:none}

.fav-row{display:flex;gap:16rpx}
.fav{flex:1;background:#F8F8F8;border-radius:14rpx;padding:20rpx 0;text-align:center}
.fav.ferrari{background:#FFF0F0}
.fav-logo{width:48rpx;height:48rpx;margin:0 auto 6rpx;display:block}
.fav-avatar{width:48rpx;height:48rpx;border-radius:24rpx;margin:0 auto 6rpx;display:block}
.fav-name{font-size:22rpx;font-weight:600;color:#333;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.h-row{display:flex;align-items:center;padding:14rpx 0}
.h-row+.h-row{border-top:1rpx solid #F5F5F5}
.h-l{font-size:24rpx;color:#999;width:120rpx}
.h-m{flex:1;display:flex;gap:6rpx;flex-wrap:wrap}
.h-tag{font-size:20rpx;padding:2rpx 8rpx;border-radius:4rpx;background:#F5F5F5;color:#666}
.h-tag.hit{background:#E8F5E9;color:#2E7D32}
.h-tag.miss{background:#FFF0F0;color:#C62828}
.h-r{font-size:26rpx;font-weight:700;color:#52C41A;font-family:monospace}

.report{background:#F8F8F8;border-radius:14rpx;padding:24rpx;text-align:center}
.rp-t{font-size:28rpx;font-weight:600;color:#333;display:block}
.rp-s{font-size:22rpx;color:#999;display:block;margin-top:8rpx}

.pro{background:#fff;border-radius:20rpx;padding:28rpx;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.pro-l{flex:1}
.pro-t{font-size:28rpx;font-weight:600;color:#1a1a1a;display:block}
.pro-s{font-size:22rpx;color:#999;display:block;margin-top:4rpx}
.pro-btn{background:#E8F5E9;color:#2E7D32;padding:14rpx 28rpx;border-radius:24rpx;font-size:26rpx;font-weight:600}
.footer-text{font-size:22rpx;color:#999}

/* 弹窗 */
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);z-index:200;display:flex;align-items:center;justify-content:center}
.modal-box{background:#fff;border-radius:24rpx;width:640rpx;max-height:70vh;overflow-y:auto;padding:28rpx 24rpx}
.modal-title{font-size:28rpx;font-weight:600;color:#333;display:block;text-align:center;margin-bottom:20rpx}
.modal-grid{display:flex;flex-wrap:wrap;gap:8rpx}
.modal-item{width:calc(33.33% - 6rpx);text-align:center;padding:14rpx 4rpx;background:#F8F8F8;border-radius:8rpx;font-size:22rpx;color:#333;box-sizing:border-box;overflow:hidden}
.modal-item:active{background:#FFF0F0;color:#E10600}
.modal-cancel{display:block;text-align:center;padding:18rpx 0;margin-top:16rpx;font-size:24rpx;color:#999;border-top:1rpx solid #F0F0F0}


.edit-tag{font-size:20rpx;color:#E10600;margin-left:6rpx;font-weight:400}
.edit-row{display:flex;align-items:center;justify-content:center;gap:12rpx;margin-top:4rpx}
.edit-input{border:2rpx solid #E10600;border-radius:8rpx;padding:6rpx 12rpx;font-size:28rpx;width:260rpx;text-align:center}
.edit-ok{font-size:24rpx;color:#fff;background:#E10600;padding:6rpx 16rpx;border-radius:6rpx}
.edit-cancel{font-size:24rpx;color:#999}
