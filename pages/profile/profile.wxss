.page { padding: 0 32rpx 120rpx; background: #F5F5F5; min-height: 100vh; }

.header { text-align: center; padding: 56rpx 0 36rpx; }
.avt { width: 80rpx; height: 80rpx; background: #E10600; border-radius: 40rpx; margin: 0 auto 14rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.nick { font-size: 34rpx; font-weight: 700; color: #1a1a1a; display: block; }
.since { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }

.stats { display: flex; align-items: center; justify-content: center; margin-bottom: 40rpx; gap: 0; }
.st { text-align: center; min-width: 140rpx; }
.st-v { font-size: 44rpx; font-weight: 700; color: #1a1a1a; display: block; font-family: -apple-system; }
.st-v.green { color: #52C41A; }
.st-l { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.st-div { width: 1rpx; height: 56rpx; background: #E8E8E8; }

.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 24rpx; }
.card-hd { font-size: 28rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 20rpx; }

.fav-row { display: flex; gap: 16rpx; }
.fav { flex: 1; background: #F8F8F8; border-radius: 14rpx; padding: 20rpx 16rpx; text-align: center; }
.fav-icon { font-size: 36rpx; display: block; margin-bottom: 8rpx; }
.fav-name { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.fav-sub { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.h-row { display: flex; align-items: center; padding: 16rpx 0; }
.h-row + .h-row { border-top: 1rpx solid #F5F5F5; }
.h-l { font-size: 24rpx; color: #999; width: 130rpx; }
.h-m { font-size: 24rpx; color: #555; flex: 1; }
.h-r { font-size: 28rpx; font-weight: 700; color: #52C41A; font-family: -apple-system; }

.report { background: #F8F8F8; border-radius: 14rpx; padding: 24rpx; text-align: center; }
.rp-t { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.rp-s { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }

.pro { background: #fff; border-radius: 20rpx; padding: 28rpx; display: flex; align-items: center; justify-content: space-between; }
.pro-l { flex: 1; }
.pro-t { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.pro-s { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.pro-btn { background: #E10600; color: #fff; padding: 14rpx 28rpx; border-radius: 24rpx; font-size: 26rpx; font-weight: 600; }
