.page { padding: 0 32rpx; }
.profile-top { text-align: center; padding: 32rpx 0 24rpx; }
.avatar { width: 96rpx; height: 96rpx; background: #E10600; border-radius: 50%; margin: 0 auto 12rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.nick { font-size: 36rpx; font-weight: 600; color: #333; display: block; }
.since { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.streak { display: inline-block; margin-top: 8rpx; background: rgba(225,6,0,0.08); color: #E10600; font-size: 20rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 16rpx; }
.team-cards { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.tc { flex: 1; background: #fff; border-radius: 12rpx; padding: 24rpx; text-align: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.tc-icon { font-size: 48rpx; display: block; margin-bottom: 8rpx; }
.tc-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tc-sub { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.stats-row { display: flex; gap: 8rpx; margin-bottom: 24rpx; }
.stat { flex: 1; background: #fff; border-radius: 10rpx; padding: 24rpx; text-align: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.stat-v { font-size: 36rpx; font-weight: 600; color: #333; display: block; }
.stat-l { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.card-title { font-size: 24rpx; color: #999; margin-bottom: 12rpx; font-weight: 600; }
.dr-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-top: 1rpx solid #F0F0F0; font-size: 28rpx; }
.hit { color: #52C41A; font-weight: 600; }
.pro-card { background: #fff; border-radius: 16rpx; padding: 32rpx; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.pro-info { flex: 1; }
.pro-title { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.pro-sub { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.pro-btn { background: #E10600; color: #fff; padding: 16rpx 32rpx; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; }
.page { padding-bottom: 120rpx; }


.nav-bar { display: flex; align-items: center; height: 88rpx; }
