.page { padding: 0 32rpx 120rpx; background: #F5F5F5; min-height: 100vh; }

.header { text-align: center; padding: 56rpx 0 24rpx; }
.avt { width: 80rpx; height: 80rpx; background: #E10600; border-radius: 40rpx; margin: 0 auto 14rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 700; color: #fff; }
.nick { font-size: 34rpx; font-weight: 700; color: #1a1a1a; display: block; }
.streak-badge { display: inline-block; margin-top: 12rpx; background: #FFF3E0; color: #E65100; font-size: 22rpx; font-weight: 600; padding: 6rpx 20rpx; border-radius: 20rpx; }

.stats { display: flex; justify-content: center; margin-bottom: 40rpx; gap: 32rpx; }
.st { text-align: center; }
.st-v { font-size: 44rpx; font-weight: 700; color: #1a1a1a; display: block; font-family: SF Mono,monospace; }
.st-v.green { color: #52C41A; }
.st-l { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 24rpx; }
.card-hd { font-size: 28rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 20rpx; }

.fav-row { display: flex; gap: 16rpx; }
.fav { flex: 1; background: #F8F8F8; border-radius: 14rpx; padding: 20rpx 0; text-align: center; }
.fav.ferrari { background: #FFF0F0; }
.fav-icon { font-size: 36rpx; display: block; margin-bottom: 8rpx; }
.fav-name { font-size: 26rpx; font-weight: 600; color: #333; display: block; }

.h-row { display: flex; align-items: center; padding: 16rpx 0; }
.h-row + .h-row { border-top: 1rpx solid #F5F5F5; }
.h-l { font-size: 24rpx; color: #999; width: 120rpx; }
.h-m { flex: 1; display: flex; gap: 8rpx; flex-wrap: wrap; }
.h-tag { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 6rpx; background: #F5F5F5; color: #666; }
.h-tag.hit { background: #E8F5E9; color: #2E7D32; }
.h-tag.miss { background: #FFF0F0; color: #C62828; }
.h-r { font-size: 28rpx; font-weight: 700; color: #52C41A; font-family: SF Mono,monospace; }

.report { background: #F8F8F8; border-radius: 14rpx; padding: 24rpx; text-align: center; }
.rp-t { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.rp-s { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }

.pro { background: #fff; border-radius: 20rpx; padding: 28rpx; display: flex; align-items: center; justify-content: space-between; }
.pro-l { flex: 1; }
.pro-t { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.pro-s { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.pro-btn { background: #E8F5E9; color: #2E7D32; padding: 14rpx 28rpx; border-radius: 24rpx; font-size: 26rpx; font-weight: 600; }
.footer-text { font-size:22rpx;color:#999; }

.edit-hint { font-size:22rpx; color:#E10600; font-weight:400; margin-left:8rpx; }
.picker-mask { position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:200;display:flex;align-items:flex-end; }
.picker-box { background:#fff;border-radius:24rpx 24rpx 0 0;width:100%;max-height:60vh;padding:32rpx 32rpx 0; }
.picker-title { font-size:28rpx;font-weight:600;color:#333;display:block;text-align:center;margin-bottom:20rpx; }
.picker-list { max-height:40vh; }
.picker-item { padding:24rpx 0;text-align:center;font-size:28rpx;color:#333;border-top:1rpx solid #F0F0F0; }
.picker-item:active { background:#F8F8F8; }
.picker-close { display:block;text-align:center;padding:28rpx 0;font-size:28rpx;color:#999;border-top:1rpx solid #F0F0F0;margin-top:8rpx; }
