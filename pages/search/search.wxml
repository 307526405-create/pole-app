<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索车手、车队、赛道..." bindinput="onInput" value="{{keyword}}" focus/>
    <text class="search-cancel" bind:tap="onBack">取消</text>
  </view>
  <scroll-view class="search-results" scroll-y wx:if="{{keyword}}">
    <view wx:for="{{results}}" wx:key="name" class="result-item">
      <text class="ri-name">{{item.name}}</text>
      <text class="ri-sub">{{item.sub}}</text>
    </view>
    <view class="no-result" wx:if="{{results.length===0}}">
      <text>暂无结果</text>
    </view>
  </scroll-view>
</view>
