.page { padding: 0 32rpx; background: #F5F5F5; min-height: 100vh; }
.search-bar { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; }
.search-input { flex: 1; height: 72rpx; background: #fff; border-radius: 36rpx; padding: 0 32rpx; font-size: 28rpx; }
.search-cancel { font-size: 28rpx; color: #999; }
.search-results { padding-top: 16rpx; }
.result-item { background: #fff; padding: 24rpx 32rpx; border-radius: 12rpx; margin-bottom: 12rpx; }
.ri-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.ri-sub { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }
.no-result { text-align: center; padding: 80rpx 0; font-size: 28rpx; color: #999; }
