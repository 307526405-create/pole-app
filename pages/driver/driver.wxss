.page { background:#F5F5F5; min-height:100vh; padding-bottom:120rpx; }
.nav-bar { display:flex; align-items:center; height:88rpx; padding:0 32rpx; }
.back { font-size:36rpx; color:#333; margin-right:16rpx; }
.nav-title { font-size:32rpx; font-weight:600; color:#333; }

.hero { display:flex; align-items:center; padding:40rpx 32rpx; gap:24rpx; background:#fff; margin-bottom:24rpx; }
.hero-img { width:160rpx; height:160rpx; border-radius:80rpx; }
.hero-avt { width:160rpx; height:160rpx; border-radius:80rpx; display:flex; align-items:center; justify-content:center; font-size:48rpx; font-weight:700; color:#fff; }
.hero-info { flex:1; }
.hero-num { font-size:48rpx; font-weight:800; color:#E10600; display:block; font-family:monospace; }
.hero-name { font-size:36rpx; font-weight:700; color:#1a1a1a; display:block; }
.hero-team { font-size:28rpx; color:#999; display:block; margin-top:4rpx; }
.hero-nat { font-size:24rpx; color:#999; display:block; margin-top:2rpx; }

.card { background:#fff; border-radius:20rpx; padding:32rpx; margin:0 32rpx 24rpx; }
.card-title { font-size:28rpx; font-weight:600; color:#1a1a1a; margin-bottom:20rpx; }
.stats-grid { display:flex; gap:16rpx; }
.sg { flex:1; text-align:center; background:#F8F8F8; border-radius:14rpx; padding:24rpx 8rpx; }
.sg-v { font-size:44rpx; font-weight:700; color:#1a1a1a; display:block; font-family:monospace; }
.sg-l { font-size:22rpx; color:#999; display:block; margin-top:4rpx; }
.bio { font-size:28rpx; color:#555; line-height:1.8; }
