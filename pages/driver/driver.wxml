<view style="padding:40rpx;background:#F5F5F5;min-height:100vh">
  <text style="font-size:32rpx;color:#333" bind:tap="onBack">← 返回</text>
  <view style="background:#fff;border-radius:20rpx;padding:60rpx;margin-top:32rpx;text-align:center">
    <text style="font-size:48rpx;font-weight:700;color:#E10600;display:block">#{{driver.num}}</text>
    <text style="font-size:40rpx;font-weight:700;color:#333;display:block;margin-top:16rpx">{{driver.name}}</text>
    <text style="font-size:28rpx;color:#999;display:block;margin-top:8rpx">{{driver.team}}</text>
    <text style="font-size:60rpx;display:block;margin-top:8rpx">{{driver.nationality}}</text>
  </view>
  <view style="background:#fff;border-radius:20rpx;padding:40rpx;margin-top:24rpx">
    <text style="font-size:32rpx;font-weight:600;color:#333;display:block;margin-bottom:20rpx">生涯数据</text>
    <view style="display:flex;gap:20rpx">
      <view style="flex:1;background:#F8F8F8;border-radius:16rpx;padding:30rpx;text-align:center">
        <text style="font-size:48rpx;font-weight:700;color:#333;display:block">{{driver.championships}}</text>
        <text style="font-size:24rpx;color:#999;display:block;margin-top:4rpx">世界冠军</text>
      </view>
      <view style="flex:1;background:#F8F8F8;border-radius:16rpx;padding:30rpx;text-align:center">
        <text style="font-size:48rpx;font-weight:700;color:#333;display:block">{{driver.wins}}</text>
        <text style="font-size:24rpx;color:#999;display:block;margin-top:4rpx">分站冠军</text>
      </view>
      <view style="flex:1;background:#F8F8F8;border-radius:16rpx;padding:30rpx;text-align:center">
        <text style="font-size:48rpx;font-weight:700;color:#333;display:block">{{driver.podiums}}</text>
        <text style="font-size:24rpx;color:#999;display:block;margin-top:4rpx">领奖台</text>
      </view>
    </view>
  </view>
  <view style="background:#fff;border-radius:20rpx;padding:40rpx;margin-top:24rpx">
    <text style="font-size:32rpx;font-weight:600;color:#333;display:block;margin-bottom:20rpx">简介</text>
    <text style="font-size:28rpx;color:#555;line-height:2">{{driver.desc}}</text>
  </view>
</view>
