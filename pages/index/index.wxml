<view class="page">
  <view class="nav-bar"><text class="nav-title">杆位</text><view class="nav-right">
    <view class="checkin-btn {{checkedIn ? 'done' : ''}}" bind:tap="onCheckin">{{checkedIn ? '🔥 '+streak+'天' : '签到'}}</view>
    <text class="nav-pts">PTS 156</text>
  </view></view>

  <view class="hero-card" wx:if="{{!isOffSeason}}">
    <view class="hero-badge">ROUND 10 · 🇨🇦</view>
    <view class="hero-title">加拿大大奖赛</view>
    <view class="hero-sub">维伦纽夫赛道 · 4.36km · 14弯 · DRS 3区</view>
    <view class="hero-info-row">
      <view class="hi-item"><text class="hi-lbl">最快圈纪录</text><text class="hi-val">1:11.441</text></view>
      <view class="hi-item"><text class="hi-lbl">轮胎策略</text><text class="hi-val">1停为主</text></view>
      <view class="hi-item"><text class="hi-lbl">上站西班牙</text><text class="hi-val green">+11</text></view>
    </view>
    <view class="hero-countdown">
      <view class="cd-item"><text class="cd-num">{{cd.days}}</text><text class="cd-label">天</text></view>
      <view class="cd-item"><text class="cd-num">{{cd.hours}}</text><text class="cd-label">时</text></view>
      <view class="cd-item"><text class="cd-num">{{cd.minutes}}</text><text class="cd-label">分</text></view>
    </view>
    <text class="deadline-warn">竞猜截止 周六 22:59</text>
    <button class="btn-go" bind:tap="onPredict">开始竞猜</button>
    <text class="participants">128人已猜</text>
  </view>

  <!-- 每日一题（全宽） -->
  <view class="card quiz-card {{quizDone ? 'done' : ''}}">
    <view class="card-title">🎯 每日一题</view>
    <text class="quiz-q">{{quiz.question}}</text>
    <view class="quiz-opts" wx:if="{{!quizDone}}">
      <view class="qo" wx:for="{{quiz.options}}" wx:key="*this" bind:tap="pickQuiz" data-idx="{{index}}">{{item}}</view>
    </view>
    <view class="quiz-done" wx:if="{{quizDone}}">
      <text class="qd-icon">{{quizResult.correct ? '✅ 答对！+1分' : '❌ '+quiz.answer}}</text>
      <text class="qd-exp">{{quiz.explanation}}</text>
    </view>
  </view>

  <!-- 冷知识（全宽，横向滑动3条） -->
  <view class="card">
    <view class="card-title">💡 冷知识</view>
    <swiper class="trivia-swiper" indicator-dots autoplay interval="5000" circular>
      <swiper-item wx:for="{{trivias}}" wx:key="*this">
        <text class="trivia-text">{{item}}</text>
      </swiper-item>
    </swiper>
  </view>

  <view class="card">
    <view class="card-title">最新资讯</view>
    <view class="info-item" wx:for="{{news}}" wx:key="title">
      <view class="info-header" bind:tap="toggleNews" data-idx="{{index}}">
        <view class="info-tag">{{item.tag}}</view><text class="info-title">{{item.title}}</text><text class="info-arrow">{{item.expanded ? '▾' : '▸'}}</text>
      </view>
      <text class="info-time">{{item.time}}</text>
      <view class="info-body" wx:if="{{item.expanded}}"><text>{{item.summary}}</text></view>
    </view>
  </view>

  <view class="loot-float {{lootOpened ? 'opened' : ''}}" bind:tap="openLoot">
    <text class="loot-float-icon">{{lootOpened ? '✅' : '🎁'}}</text>
  </view>
  <view class="loot-toast" wx:if="{{showLootToast}}">
    <text class="lt-icon">{{lootResult.icon}}</text>
    <text class="lt-text">{{lootResult.text}}</text>
  </view>
</view>
