<view class="page">
  <view class="nav-bar"><text class="nav-title">杆位</text><view class="nav-right">
    <view class="checkin-btn {{checkedIn ? 'done' : ''}}" bind:tap="onCheckin">{{checkedIn ? '🔥 连续'+streak+'天' : '签到 +1'}}</view>
    <text class="nav-pts">PTS 156</text>
  </view></view>

  <view class="hero-card" wx:if="{{!isOffSeason}}">
    <view class="hero-badge">ROUND 10 · 🇨🇦</view>
    <view class="hero-title">加拿大大奖赛</view>
    <view class="hero-sub">维伦纽夫赛道 · 4.36km · 14弯 · DRS 3区</view>
    <view class="season-bar"><view class="season-fill" style="width:42%"></view></view>
    <text class="season-label">赛季进度 10/24</text>
    <view class="hero-track">
      <view class="ht-item"><text class="ht-lbl">最快圈纪录</text><text class="ht-val">1:11.441</text><text class="ht-drv">Verstappen 2024</text></view>
      <view class="ht-item"><text class="ht-lbl">轮胎策略</text><text class="ht-val">1停为主</text><text class="ht-drv">C3/C4/C5</text></view>
    </view>
    <view class="hero-countdown">
      <view class="cd-item"><text class="cd-num">{{cd.days}}</text><text class="cd-label">天</text></view>
      <view class="cd-item"><text class="cd-num">{{cd.hours}}</text><text class="cd-label">时</text></view>
      <view class="cd-item"><text class="cd-num">{{cd.minutes}}</text><text class="cd-label">分</text></view>
    </view>
    <text class="deadline-warn">⏰ 竞猜截止：周六 22:59</text>
    <view class="hero-times"><text class="ht-label">排位赛 周六 23:00</text><text class="ht-label">正赛 周日 23:00</text></view>
    <button class="btn-go" bind:tap="onPredict">开始竞猜</button>
    <text class="participants">已有 128 人参与竞猜</text>
  </view>

  <view class="hero-card offseason" wx:if="{{isOffSeason}}">
    <view class="hero-badge">2027 SEASON</view>
    <view class="hero-title">新赛季倒计时</view>
    <view class="hero-sub">澳大利亚大奖赛 · 3月8日</view>
    <view class="hero-countdown"><view class="cd-item"><text class="cd-num">{{cd.days}}</text><text class="cd-label">天</text></view></view>
    <view class="offseason-tips">
      <view class="tip-item">🏎️ 冬测追踪：2月巴林</view><view class="tip-item">🔄 转会市场</view><view class="tip-item">📊 赛季报告</view>
    </view>
  </view>

  <!-- 每日三连：冷知识+历史今天+我的统计 -->
  <view class="daily-row">
    <view class="daily-card">
      <view class="daily-badge">💡 冷知识</view>
      <text class="daily-text">{{dailyTrivia}}</text>
    </view>
    <view class="daily-card">
      <view class="daily-badge">📅 历史上的今天</view>
      <text class="daily-text">{{todayInHistory}}</text>
    </view>
  </view>

  <!-- 我的进步 -->
  <view class="card">
    <view class="card-title">📈 我的竞猜</view>
    <view class="my-stats-mini">
      <view class="msm-item"><text class="msm-val">156</text><text class="msm-lbl">积分</text></view>
      <view class="msm-div"></view>
      <view class="msm-item"><text class="msm-val green">47%</text><text class="msm-lbl">准确率</text></view>
      <view class="msm-div"></view>
      <view class="msm-item"><text class="msm-val">5</text><text class="msm-lbl">连对杆位</text></view>
      <view class="msm-div"></view>
      <view class="msm-item"><text class="msm-val">#42</text><text class="msm-lbl">排名</text></view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">最新资讯</view>
    <view class="info-item" wx:for="{{news}}" wx:key="title">
      <view class="info-header" bind:tap="toggleNews" data-idx="{{index}}">
        <view class="info-tag">{{item.tag}}</view><text class="info-title">{{item.title}}</text><text class="info-arrow">{{item.expanded ? '▾' : '▸'}}</text>
      </view>
      <text class="info-time">{{item.time}}</text>
      <view class="info-body" wx:if="{{item.expanded}}"><text>{{item.summary}}</text></view>
    </view>
  </view>

  <view class="card">
    <view class="score-row">
      <view class="score-main"><text class="score-num">+11</text><text class="score-sub">上站 · 西班牙</text></view>
      <view class="score-last">
        <view class="last-detail"><text class="ld-item">✅ 杆位(23%)</text><text class="ld-item">✅ 领奖台(8%)</text><text class="ld-item miss">最快圈</text></view>
      </view>
    </view>
    <view class="review-divider"></view>
    <view class="review-detail">
      <view class="rd-row"><text>杆位</text><text class="hit">Verstappen ✅</text></view>
      <view class="rd-row"><text>领奖台</text><text class="hit">2/3 正确 ✅</text></view>
      <view class="rd-row"><text>最快圈</text><text class="miss">Norris 猜错</text></view>
    </view>
    <button class="share-btn" open-type="share">分享到微信</button>
  </view>
</view>
