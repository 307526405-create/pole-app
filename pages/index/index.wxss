.page { padding: 0 32rpx 120rpx; }
.nav-bar { display: flex; justify-content: space-between; align-items: center; height: 88rpx; }
.nav-title { font-size: 40rpx; font-weight: 800; color: #E10600; letter-spacing: -1rpx; }
.nav-right { display: flex; align-items: center; gap: 12rpx; }
.checkin-btn { background: #E10600; color: #fff; font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.checkin-btn.done { background: #F0F0F0; color: #999; }
.nav-pts { font-size: 28rpx; color: #E10600; font-weight: 600; }
.nav-brand { display: flex; align-items: baseline; gap: 8rpx; }
.nav-en { font-size: 22rpx; color: #666; letter-spacing: 3rpx; border-left: 2rpx solid #E10600; padding-left: 12rpx; }

.hero-card { background: linear-gradient(135deg, #1a0000 0%, #0a0a0a 100%); border-radius: 24rpx; padding: 40rpx 32rpx 36rpx; margin: 12rpx 0 24rpx; color: #fff; position: relative; overflow: hidden; text-align: center; }
.hero-card::before { content:''; position:absolute; inset:0; background: repeating-linear-gradient(90deg, transparent, transparent 40rpx, rgba(225,6,0,.03) 40rpx, rgba(225,6,0,.03) 80rpx); z-index:0; }
.hero-card::after { content:''; position:absolute; top:-40rpx; right:-40rpx; width:200rpx; height:200rpx; background: radial-gradient(circle, rgba(225,6,0,.15), transparent 70%); z-index:0; }
.badge { font-size: 22rpx; color: rgba(255,255,255,.55); margin-bottom: 8rpx; letter-spacing: 2rpx; position: relative; z-index: 1; display: block; }
.title { font-size: 52rpx; font-weight: 700; margin-bottom: 4rpx; position: relative; z-index: 1; display: block; }
.sub { font-size: 24rpx; color: rgba(255,255,255,.45); margin-bottom: 28rpx; position: relative; z-index: 1; display: block; }

.pg { display: flex; align-items: center; justify-content: center; gap: 10rpx; margin-bottom: 28rpx; position: relative; z-index: 1; }
.pg-track { width: 160rpx; height: 4rpx; background: rgba(255,255,255,.06); border-radius: 2rpx; overflow: hidden; }
.pg-fill { height: 100%; background: #E10600; border-radius: 2rpx; box-shadow: 0 0 8rpx rgba(225,6,0,.4); transition: width .3s; }
.pg-text { font-size: 20rpx; color: rgba(255,255,255,.35); }

.cd { display: flex; justify-content: center; align-items: center; margin-bottom: 20rpx; position: relative; z-index: 1; }
.cd-item { text-align: center; min-width: 120rpx; }
.cd-num { font-size: 80rpx; font-weight: 700; display: block; line-height: 1; font-family: monospace; text-shadow: 0 0 32rpx rgba(225,6,0,.4); }
.cd-label { font-size: 22rpx; color: rgba(255,255,255,.3); display: block; margin-top: 4rpx; }
.cd-sep { font-size: 64rpx; color: rgba(255,255,255,.06); padding: 0 4rpx; font-family: monospace; padding-bottom: 20rpx; }

.urgency { margin-bottom: 20rpx; position: relative; z-index: 1; font-size: 24rpx; color: #E10600; font-weight: 600; }
.btn { width: 100%; height: 100rpx; background: #E10600; color: #fff; border: none; border-radius: 20rpx; font-size: 34rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 40rpx rgba(225,6,0,.3); position: relative; z-index: 1; }
button::after { border: none; }

.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.card-title { font-size: 24rpx; color: #999; margin-bottom: 16rpx; font-weight: 600; }
.quiz-card { background: linear-gradient(135deg, #FFF8E1, #fff); }
.quiz-card.done { background: #F5F5F5; }
.quiz-q { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; line-height: 1.4; }
.quiz-opts { display: flex; flex-wrap: wrap; gap: 12rpx; }
.qo { padding: 16rpx 32rpx; background: #F5F5F5; border-radius: 12rpx; font-size: 24rpx; color: #333; }
.qo:active { background: #E10600; color: #fff; }
.quiz-done { display: flex; flex-direction: column; gap: 8rpx; }
.qd-icon { font-size: 28rpx; font-weight: 600; color: #333; }
.qd-exp { font-size: 22rpx; color: #999; line-height: 1.5; }
.trivia-swiper { height: 120rpx; }
.trivia-text { font-size: 28rpx; color: #333; line-height: 1.6; padding: 0 8rpx; display: block; }
.info-item { padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.info-item:last-child { border-bottom: none; padding-bottom: 0; }
.info-header { display: flex; align-items: center; gap: 12rpx; }
.info-tag { background: rgba(225,6,0,0.08); color: #E10600; font-size: 20rpx; font-weight: 600; padding: 2rpx 12rpx; border-radius: 4rpx; flex-shrink: 0; }
.info-title { font-size: 28rpx; color: #333; flex: 1; }
.info-arrow { font-size: 24rpx; color: #999; flex-shrink: 0; }
.info-body { margin-top: 12rpx; padding: 16rpx; background: #F5F5F5; border-radius: 8rpx; font-size: 24rpx; color: #666; line-height: 1.6; }
.loot-float { position: fixed; right: 32rpx; bottom: 200rpx; width: 88rpx; height: 88rpx; background: linear-gradient(135deg, #FFC107, #FF9800); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(255,152,0,0.3); z-index: 10; animation: bounce 2s infinite; }
.loot-float.opened { background: #E5E5E5; animation: none; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); }
.loot-float-icon { font-size: 36rpx; }
@keyframes bounce { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-6rpx) } }
.loot-toast { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background: #fff; border-radius: 24rpx; padding: 40rpx 48rpx; text-align: center; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15); z-index: 100; animation: pop .3s ease; }
@keyframes pop { from { opacity:0; transform: translate(-50%,-50%) scale(.8); } to { opacity:1; transform: translate(-50%,-50%) scale(1); } }
.lt-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.lt-text { font-size: 28rpx; font-weight: 600; color: #333; }
.search-icon { font-size: 32rpx; margin-right: 4rpx; }
