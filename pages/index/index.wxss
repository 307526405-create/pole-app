.page { padding: 16rpx 32rpx 0; }

.race-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border-left: 8rpx solid #E10600;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.race-round { font-size: 20rpx; color: #E10600; font-weight: 600; letter-spacing: 2rpx; }
.race-title { font-size: 36rpx; font-weight: 600; color: #333; margin: 8rpx 0 4rpx; }
.race-meta { font-size: 24rpx; color: #666; margin-bottom: 16rpx; }

.track-stats {
  display: flex; gap: 32rpx; padding: 16rpx 0;
  border-top: 1rpx solid #F0F0F0; border-bottom: 1rpx solid #F0F0F0; margin-bottom: 16rpx;
}
.ts-item { flex: 1; display: flex; flex-direction: column; gap: 2rpx; }
.ts-label { font-size: 18rpx; color: #999; }
.ts-value { font-size: 28rpx; font-weight: 600; color: #333; }
.ts-driver { font-size: 20rpx; color: #666; }

.race-times { display: flex; gap: 48rpx; margin-bottom: 24rpx; }
.time-label { font-size: 20rpx; color: #999; }
.time-value { font-size: 28rpx; font-weight: 600; color: #333; }

.race-btns { display: flex; flex-direction: column; gap: 16rpx; }

.card {
  background: #fff; border-radius: 16rpx; padding: 32rpx;
  margin-bottom: 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.card-title { font-size: 24rpx; color: #999; margin-bottom: 16rpx; font-weight: 600; }

.score-panel { display: flex; align-items: center; gap: 24rpx; }
.sp-left { flex: 1; text-align: right; }
.sp-label { font-size: 20rpx; color: #999; }
.sp-change { font-size: 28rpx; font-weight: 600; color: #52C41A; }
.sp-center { text-align: center; }
.sp-num { font-size: 64rpx; font-weight: 600; color: #333; line-height: 1; }
.sp-sub { font-size: 24rpx; color: #666; margin-top: 4rpx; }
.sp-right { flex: 1; }
.sp-row { font-size: 24rpx; padding: 4rpx 0; color: #52C41A; }
.sp-row .miss { color: #999; }

.news-scroll { display: flex; gap: 16rpx; white-space: nowrap; margin-bottom: 24rpx; }
.news-item {
  background: #fff; border-radius: 8rpx; padding: 16rpx 24rpx;
  font-size: 24rpx; color: #666; display: flex; align-items: center; gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); flex-shrink: 0;
}
.news-dot { width: 8rpx; height: 8rpx; background: #E10600; border-radius: 50%; flex-shrink: 0; }

.review-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-top: 1rpx solid #F0F0F0; font-size: 28rpx; }
.hit { color: #52C41A; font-weight: 600; }
.miss { color: #999; }
