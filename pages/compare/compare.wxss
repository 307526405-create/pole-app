.page{background:#F5F5F5;min-height:100vh;padding-bottom:120rpx}
.nav-bar{display:flex;align-items:center;height:88rpx;padding:0 32rpx}
.back{font-size:36rpx;color:#333;margin-right:16rpx}
.nav-title{font-size:32rpx;font-weight:600;color:#333}
.pick-row{display:flex;align-items:center;justify-content:center;gap:16rpx;padding:32rpx}
.pr-item{background:#fff;border-radius:12rpx;padding:24rpx 32rpx;font-size:28rpx;font-weight:600;color:#333;text-align:center;min-width:200rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04)}
.vs{font-size:28rpx;font-weight:700;color:#E10600}
.card{background:#fff;border-radius:20rpx;padding:32rpx;margin:0 32rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.c-row{display:flex;align-items:center;padding:20rpx 0;border-bottom:1rpx solid #F5F5F5}
.c-label{font-size:26rpx;color:#999;width:140rpx}
.c-v1{flex:1;font-size:32rpx;font-weight:700;color:#E10600;text-align:center;font-family:monospace}
.c-v2{flex:1;font-size:32rpx;font-weight:700;color:#333;text-align:center;font-family:monospace}
