d/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/racingbulls/yuktsu01/2026racingbullsyuktsu01right.webp"}, {"num": 6, "name": "伊萨克·哈贾尔", "team": "红牛", "nationality": "🇫🇷", "desc": "F2冠军升入F1红牛。", "championships": "0", "wins": "0", "podiums": "0", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/redbullracing/isahad01/2026redbullracingisahad01right.webp"}, {"num": 31, "name": "埃斯特班·奥康", "team": "哈斯", "nationality": "🇫🇷", "desc": "2021匈牙利站夺冠。2026加盟哈斯。", "championships": "0", "wins": "1+", "podiums": "3+", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/haasf1team/estoco01/2026haasf1teamestoco01right.webp"}, {"num": 87, "name": "奥利弗·贝尔曼", "team": "哈斯", "nationality": "🇬🇧", "desc": "法拉利青训出品。2025首秀得分。", "championships": "0", "wins": "0", "podiums": "0", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/haasf1team/olibea01/2026haasf1teamolibea01right.webp"}, {"num": 27, "name": "尼科·霍肯伯格", "team": "奥迪", "nationality": "🇩🇪", "desc": "德国老将。2026赛季加盟奥迪。", "championships": "0", "wins": "0", "podiums": "0", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/audi/nichul01/2026audinichul01right.webp"}, {"num": 5, "name": "加布里埃尔·博托莱托", "team": "奥迪", "nationality": "🇧🇷", "desc": "巴西新星。F3冠军升入F1。", "championships": "0", "wins": "0", "podiums": "0", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/audi/gabbor01/2026audigabbor01right.webp"}, {"num": 18, "name": "兰斯·斯特罗尔", "team": "阿斯顿马丁", "nationality": "🇨🇦", "desc": "加拿大车手。2020赛季有领奖台。", "championships": "0", "wins": "0", "podiums": "3+", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/astonmartin/lanstr01/2026astonmartinlanstr01right.webp"}, {"num": 77, "name": "瓦尔特利·博塔斯", "team": "凯迪拉克", "nationality": "🇫🇮", "desc": "10次分站冠军。2026加盟凯迪拉克。", "championships": "0", "wins": "10+", "podiums": "67+", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/cadillac/valbot01/2026cadillacvalbot01right.webp"}, {"num": 43, "name": "弗朗哥·科拉平托", "team": "阿尔派", "nationality": "🇦🇷", "desc": "阿根廷车手。2024首秀得分。", "championships": "0", "wins": "0", "podiums": "0", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/alpine/fracol01/2026alpinefracol01right.webp"}, {"num": 41, "name": "阿尔维德·林德布拉德", "team": "小红牛", "nationality": "🇬🇧", "desc": "红牛青训新星。2026年F1首秀。", "championships": "0", "wins": "0", "podiums": "0", "img": "https://media.formula1.com/image/upload/c_fill,w_400,h_400,g_face/q_auto/v1740000001/common/f1/2026/racingbulls/arvlin01/2026racingbullsarvlin01right.webp"}],
  circuits:[{"flag": "🇦🇺", "name": "阿尔伯特公园赛道", "location": "澳大利亚墨尔本", "length": "5.28km", "turns": 14, "drs": 2, "lapRecord": "1:19.813", "firstGP": "1996", "capacity": "8万", "desc": "赛季揭幕战传统举办地。公园赛道环绕阿尔伯特湖。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Australia_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇨🇳", "name": "上海国际赛车场", "location": "中国上海", "length": "5.45km", "turns": 16, "drs": 2, "lapRecord": "1:32.238", "firstGP": "2004", "capacity": "20万", "desc": "独特的\"上\"字形布局。1.2km超长直道。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/China_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇯🇵", "name": "铃鹿赛道", "location": "日本铃鹿", "length": "5.81km", "turns": 18, "drs": 1, "lapRecord": "1:28.197", "firstGP": "1987", "capacity": "15.5万", "desc": "F1唯一8字型赛道。车手最爱的赛道之一。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Japan_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇧🇭", "name": "巴林国际赛道", "location": "巴林萨基尔", "length": "5.41km", "turns": 15, "drs": 3, "lapRecord": "1:31.447", "firstGP": "2004", "capacity": "7万", "desc": "中东沙漠赛道。赛季早期夜赛。刹车磨损是最大挑战。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Bahrain_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇸🇦", "name": "吉达滨海赛道", "location": "沙特阿拉伯吉达", "length": "6.17km", "turns": 27, "drs": 3, "lapRecord": "1:30.734", "firstGP": "2021", "capacity": "5万", "desc": "F1最快街道赛。27个弯道全年最多。红海沿岸夜赛。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Saudi_Arabia_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇺🇸", "name": "迈阿密国际赛道", "location": "美国迈阿密", "length": "5.41km", "turns": 19, "drs": 3, "lapRecord": "1:27.925", "firstGP": "2022", "capacity": "8万", "desc": "围绕硬石体育场建造。美国最年轻的F1赛道。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Miami_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇨🇦", "name": "维伦纽夫赛道", "location": "加拿大蒙特利尔", "length": "4.36km", "turns": 14, "drs": 3, "lapRecord": "1:11.441", "firstGP": "1978", "capacity": "10万", "desc": "半街道赛道。冠军墙是F1最著名的地标之一。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Canada_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇲🇨", "name": "蒙特卡洛赛道", "location": "摩纳哥", "length": "3.34km", "turns": 19, "drs": 1, "lapRecord": "1:12.909", "firstGP": "1950", "capacity": "3.7万", "desc": "F1最具代表性的街道赛。排位赛几乎决定正赛。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Monaco_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇪🇸", "name": "巴塞罗那赛道", "location": "西班牙巴塞罗那", "length": "4.66km", "turns": 16, "drs": 2, "lapRecord": "1:15.647", "firstGP": "1991", "capacity": "14万", "desc": "F1传统测试赛道。车队最熟悉的赛道之一。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Spain_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇦🇹", "name": "红牛环赛道", "location": "奥地利施皮尔伯格", "length": "4.32km", "turns": 10, "drs": 3, "lapRecord": "1:04.671", "firstGP": "1970", "capacity": "10万", "desc": "F1最短赛道之一。红牛车队主场。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Austria_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇬🇧", "name": "银石赛道", "location": "英国银石", "length": "5.89km", "turns": 18, "drs": 2, "lapRecord": "1:27.097", "firstGP": "1950", "capacity": "15万", "desc": "F1首届比赛举办地。高速弯群是F1最美弯道。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Great_Britain_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇧🇪", "name": "斯帕赛道", "location": "比利时斯帕", "length": "7.0km", "turns": 19, "drs": 2, "lapRecord": "1:46.286", "firstGP": "1950", "capacity": "7万", "desc": "F1最长赛道之一。Eau Rouge弯道最具挑战性。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Belgium_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇭🇺", "name": "亨格罗宁赛道", "location": "匈牙利布达佩斯", "length": "4.38km", "turns": 14, "drs": 1, "lapRecord": "1:16.207", "firstGP": "1986", "capacity": "7万", "desc": "被称为\"没有墙的摩纳哥\"。弯道多直道少。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Hungary_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇳🇱", "name": "赞德沃特赛道", "location": "荷兰赞德沃特", "length": "4.26km", "turns": 14, "drs": 2, "lapRecord": "1:10.567", "firstGP": "1952", "capacity": "10.5万", "desc": "维斯塔潘主场。独特的倾斜弯道设计。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Netherlands_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇮🇹", "name": "蒙扎赛道", "location": "意大利蒙扎", "length": "5.79km", "turns": 11, "drs": 2, "lapRecord": "1:21.046", "firstGP": "1950", "capacity": "11.8万", "desc": "\"速度圣殿\"。F1全年最高速赛道。法拉利主场。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Italy_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇪🇸", "name": "Madring赛道", "location": "西班牙马德里", "length": "5.47km", "turns": 20, "drs": 2, "lapRecord": "待定", "firstGP": "2026", "capacity": "11万", "desc": "2026赛季新赛道。马德里首次举办F1大奖赛。", "map": ""}, {"flag": "🇦🇿", "name": "巴库城市赛道", "location": "阿塞拜疆巴库", "length": "6.0km", "turns": 20, "drs": 2, "lapRecord": "1:43.009", "firstGP": "2016", "capacity": "1.8万", "desc": "F1第二长赛道。穿越巴库古城的最窄弯道。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Baku_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇸🇬", "name": "滨海湾赛道", "location": "新加坡", "length": "4.94km", "turns": 19, "drs": 2, "lapRecord": "1:41.905", "firstGP": "2008", "capacity": "9万", "desc": "F1首场夜赛。23个弯道全年最多。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Singapore_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇺🇸", "name": "美洲赛道", "location": "美国奥斯汀", "length": "5.51km", "turns": 20, "drs": 2, "lapRecord": "1:36.169", "firstGP": "2012", "capacity": "12万", "desc": "美国大奖赛主场。1号弯的上坡急弯是标志。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/USA_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇲🇽", "name": "罗德里格斯赛道", "location": "墨西哥城", "length": "4.3km", "turns": 17, "drs": 2, "lapRecord": "1:17.774", "firstGP": "1963", "capacity": "11万", "desc": "高海拔赛道(2285m)。体育场赛段气氛最热烈。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Mexico_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇧🇷", "name": "英特拉格斯赛道", "location": "巴西圣保罗", "length": "4.31km", "turns": 15, "drs": 2, "lapRecord": "1:10.540", "firstGP": "1973", "capacity": "6万", "desc": "塞纳的故乡。逆时针赛道。雨战经典频出。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Brazil_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇺🇸", "name": "拉斯维加斯街道", "location": "美国拉斯维加斯", "length": "6.12km", "turns": 17, "drs": 2, "lapRecord": "1:35.490", "firstGP": "2023", "capacity": "10万", "desc": "F1最新赛道。穿越拉斯维加斯大道的夜赛。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Las_Vegas_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇶🇦", "name": "卢赛尔国际赛道", "location": "卡塔尔卢赛尔", "length": "5.38km", "turns": 16, "drs": 1, "lapRecord": "1:24.319", "firstGP": "2021", "capacity": "5万", "desc": "中东夜赛。高速弯道+长直道的组合。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Qatar_Circuit.png.transform/7col-retina/image.png"}, {"flag": "🇦🇪", "name": "亚斯码头赛道", "location": "阿布扎比", "length": "5.28km", "turns": 16, "drs": 2, "lapRecord": "1:26.103", "firstGP": "2009", "capacity": "6万", "desc": "F1赛季收官战。黄昏起跑的昼夜转换。", "map": "https://www.formula1.com/content/dam/fom-website/2018-redesign-assets/Circuit%20maps%2016x9/Abu_Dhabi_Circuit.png.transform/7col-retina/image.png"}]},
  onLoad(){
    var t=this
    wx.request({url:API+"/races",success(r){var n=new Date;t.setData({races:(r.data.data||[]).map(function(rr){var isTbd=rr.name&&(rr.name.indexOf("Bahrain")>=0||rr.name.indexOf("Saudi")>=0);var s=isTbd?"tbd":(new Date(rr.date)<n?"done":"next");var tag=isTbd?"待定":(new Date(rr.date)<n?"已结束":"即将");return{round:rr.round,flag:FLAGS[rr.country]||"🏁",gp:RACE_CN[rr.name]||rr.name,date:rr.date.substring(5),circuit:rr.circuit,status:s,tag:tag}})})}})
    wx.request({url:API+"/standings/drivers",success(r){var d=t.data.standings;d[0]=(r.data.data||[]).map(function(dd){var m=D_CN[dd.driver_name]||[dd.driver_name,dd.driver_code||"",""];return{pos:dd.position,name:m[0],en:m[1],team:(T_CN[dd.constructor]||[dd.constructor])[0],pts:dd.points,img:m[2]}});t.setData({standings:d})}})
    wx.request({url:API+"/standings/constructors",success(r){var d=t.data.standings;d[1]=(r.data.data||[]).map(function(dd){var m=T_CN[dd.name]||[dd.name,"",""];return{pos:dd.position,name:m[0],en:m[1],pts:dd.points,img:m[2]}});t.setData({standings:d})}})
  },
  onPullDownRefresh(){this.onLoad()},switchSub(e){this.setData({subtab:parseInt(e.currentTarget.dataset.idx)})},
  switchRank(e){this.setData({rankTab:parseInt(e.currentTarget.dataset.idx)})},
  switchWiki(e){this.setData({wikiTab:parseInt(e.currentTarget.dataset.idx)})}
})