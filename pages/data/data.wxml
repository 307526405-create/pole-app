<view class="nav-bar"><text class="nav-title">数据</text></view>
<view class="tabs-fixed">
  <text class="tab {{subtab==0?'active':''}}" bind:tap="switchSub" data-idx="0">赛程</text>
  <text class="tab {{subtab==1?'active':''}}" bind:tap="switchSub" data-idx="1">积分</text>
  <text class="tab {{subtab==2?'active':''}}" bind:tap="switchSub" data-idx="2">百科</text>
</view>
<scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="state-box">
    <text class="state-icon">⏳</text>
    <text class="state-text">加载中...</text>
  </view>
  <view wx:if="{{error}}" class="state-box">
    <text class="state-icon">⚠️</text>
    <text class="state-text">加载失败</text>
    <view class="retry-btn" bind:tap="onRetry">重试</view>
  </view><view wx:if="{{subtab==0}}">
    <view wx:for="{{races}}" wx:key="round">
      <view class="cal-row" bind:tap="toggleDetail" data-idx="{{index}}">
        <text class="cal-num">{{item.round}}</text>
        <text class="cal-flag">{{item.flag}}</text>
        <view class="cal-info"><text class="cal-gp">{{item.gp}}</text><text class="cal-date">{{item.date}} · 周五-周日</text><text class="cal-circuit">{{item.circuit}}</text></view>
        <text class="cal-tag {{item.status}}">{{item.tag}}</text><text class="cal-arrow">{{item.showDetail ? "▾" : "▸"}}</text>
      </view>
      <view wx:if="{{item.showDetail}}" class="race-detail">
        <view wx:for="{{item.schedule}}" wx:key="name" class="rd-row">
          <text class="rd-session">{{item.name}}</text>
          <text class="rd-time">{{item.time}}</text>
        </view>
        <view wx:if="{{item.isSprint}}" class="rd-sprint">🏃 冲刺赛周末</view>
      </view>
    </view>
  </view>
  <!-- 积分和百科保持不变 -->
  <view wx:if="{{subtab==1}}">
    <view class="sub-tabs">
      <text class="sub-tab {{rankTab==0?'active':''}}" bind:tap="switchRank" data-idx="0">车手</text>
      <text class="sub-tab {{rankTab==1?'active':''}}" bind:tap="switchRank" data-idx="1">车队</text>
    </view>
    <view wx:for="{{standings[rankTab]}}" wx:key="pos" class="ds-row">
      <text class="ds-pos">{{item.pos}}</text>
      <image wx:if="{{item.img}}" class="ds-img" src="{{item.img}}" mode="aspectFill"/>
      <view wx:else class="ds-avatar" style="background:#E10600"><text>{{item.en}}</text></view>
      <view class="ds-info"><text class="ds-name">{{item.name}}</text><text class="ds-en">{{item.en}}</text></view>
      <text class="ds-pts">{{item.pts}}</text>
    </view>
  </view>
  <view wx:if="{{subtab==2}}">
    <view class="sub-tabs">
      <text class="sub-tab {{wikiTab==0?'active':''}}" bind:tap="switchWiki" data-idx="0">车队</text>
      <text class="sub-tab {{wikiTab==1?'active':''}}" bind:tap="switchWiki" data-idx="1">车手</text>
      <text class="sub-tab {{wikiTab==2?'active':''}}" bind:tap="switchWiki" data-idx="2">赛道</text>
    </view>
    <view wx:if="{{wikiTab==0}}">
      <view class="team-card" wx:for="{{teams}}" wx:key="name" bind:tap="goTeam" data-idx="{{index}}">
        <view class="tc-header">
          <image wx:if="{{item.logo}}" class="tch-logo" src="{{item.logo}}" mode="aspectFit"/>
          <view wx:else class="tch-logo" style="background:{{item.color}}"><text>{{item.name[0]}}</text></view>
          <view class="tch-info"><text class="tch-name">{{item.name}}</text><text class="tch-base">总部 {{item.base}} · 引擎 {{item.engine}}</text></view>
        </view>
        <text class="tc-desc">{{item.desc}}</text>
        <view class="tc-drivers">
          <view class="tcd-item"><text class="tcd-label">一号</text><text class="tcd-name">{{item.d1}}</text></view>
          <view class="tcd-item"><text class="tcd-label">二号</text><text class="tcd-name">{{item.d2}}</text></view>
          <view class="tcd-item"><text class="tcd-label">储备</text><text class="tcd-name">{{item.res}}</text></view>
        </view>
        <view class="tc-stats">
          <view class="tcs-item"><text class="tcs-val">{{item.championships}}</text><text class="tcs-lbl">冠军</text></view>
          <view class="tcs-item"><text class="tcs-val">{{item.wins}}</text><text class="tcs-lbl">分站</text></view>
          <view class="tcs-item"><text class="tcs-val">{{item.since}}</text><text class="tcs-lbl">参赛</text></view>
        </view>
      </view>
    </view>
    <view wx:if="{{wikiTab==1}}">
      <view class="team-card" wx:for="{{wikiDrivers}}" wx:key="name" bind:tap="goDriver" data-idx="{{index}}">
        <view class="tc-header">
          <image wx:if="{{item.img}}" class="tch-logo" src="{{item.img}}" mode="aspectFill" style="border-radius:50%"/>
          <view wx:else class="tch-logo" style="background:#E10600;border-radius:50%"><text>#{{item.num}}</text></view>
          <view class="tch-info"><text class="tch-name">{{item.name}}</text><text class="tch-base">{{item.team}} · {{item.nationality}}</text></view>
        </view>
        <text class="tc-desc">{{item.desc}}</text>
        <view class="tc-stats">
          <view class="tcs-item"><text class="tcs-val">{{item.championships}}</text><text class="tcs-lbl">冠军</text></view>
          <view class="tcs-item"><text class="tcs-val">{{item.wins}}</text><text class="tcs-lbl">分站</text></view>
          <view class="tcs-item"><text class="tcs-val">{{item.podiums}}</text><text class="tcs-lbl">领奖台</text></view>
        </view>
      </view>
    </view>
    <view wx:if="{{wikiTab==2}}">
      <view class="team-card" wx:for="{{circuits}}" wx:key="name">
        <view class="tc-header">
          <text class="tch-icon">{{item.flag}}</text>
          <view class="tch-info"><text class="tch-name">{{item.name}}</text><text class="tch-base">📍 {{item.location}} · {{item.length}} · {{item.turns}}弯 · DRS{{item.drs}}区</text></view>
        </view>
        <image wx:if="{{item.map}}" class="circuit-map" src="{{item.map}}" mode="widthFix"/>
        <text class="tc-desc">{{item.desc}}</text>
        <view class="tc-stats">
          <view class="tcs-item"><text class="tcs-val">{{item.lapRecord}}</text><text class="tcs-lbl">最快圈</text></view>
          <view class="tcs-item"><text class="tcs-val">{{item.firstGP}}</text><text class="tcs-lbl">首场</text></view>
          <view class="tcs-item"><text class="tcs-val">{{item.capacity}}</text><text class="tcs-lbl">观众</text></view>
        </view>
      </view>
    </view>
  </view>
  <view style="height:160rpx"></view>
  

  <view wx:if="{{showDriver}}" class="modal-mask" bind:tap="closeDriver">
    <view class="modal" catchtap="">
      <text class="modal-close" bind:tap="closeDriver">✕</text>
      <image wx:if="{{showDriver.img}}" class="modal-img" src="{{showDriver.img}}" mode="aspectFill"/>
      <view wx:else class="modal-avt"><text>#{{showDriver.num}}</text></view>
      <text class="modal-num">#{{showDriver.num}}</text>
      <text class="modal-name">{{showDriver.name}}</text>
      <text class="modal-sub">{{showDriver.team}} · {{showDriver.nationality}}</text>
      <view class="modal-section"><text class="modal-sectitle">生涯荣誉</text>
        <view class="modal-stats">
          <view class="ms"><text class="ms-v">{{showDriver.championships}}</text><text class="ms-l">世界冠军</text></view>
          <view class="ms"><text class="ms-v">{{showDriver.wins}}</text><text class="ms-l">分站冠军</text></view>
          <view class="ms"><text class="ms-v">{{showDriver.podiums}}</text><text class="ms-l">领奖台</text></view>
        </view>
      </view>
      <view class="modal-section"><text class="modal-sectitle">车手简介</text><text class="modal-desc">{{showDriver.detail}}</text></view>
    </view>
  </view>

  <view wx:if="{{showTeam}}" class="modal-mask" bind:tap="closeTeam">
    <view class="modal" catchtap="">
      <text class="modal-close" bind:tap="closeTeam">✕</text>
      <image wx:if="{{showTeam.logo}}" class="modal-logo" src="{{showTeam.logo}}" mode="aspectFit"/>
      <view wx:else class="modal-avt" style="background:{{showTeam.color}}"><text>{{showTeam.name[0]}}</text></view>
      <text class="modal-name">{{showTeam.name}}</text>
      <text class="modal-sub">总部 {{showTeam.base}} · 引擎 {{showTeam.engine}}</text>
      <view class="modal-section"><text class="modal-sectitle">车队数据</text>
        <view class="modal-stats">
          <view class="ms"><text class="ms-v">{{showTeam.championships}}</text><text class="ms-l">世界冠军</text></view>
          <view class="ms"><text class="ms-v">{{showTeam.wins}}</text><text class="ms-l">分站冠军</text></view>
          <view class="ms"><text class="ms-v">{{showTeam.since}}</text><text class="ms-l">参赛年份</text></view>
        </view>
      </view>
      <view class="modal-section"><text class="modal-sectitle">车手阵容</text>
        <view class="modal-drivers">
          <view class="md"><text class="md-label">一号</text><text class="md-name">{{showTeam.d1}}</text></view>
          <view class="md"><text class="md-label">二号</text><text class="md-name">{{showTeam.d2}}</text></view>
          <view class="md"><text class="md-label">储备</text><text class="md-name">{{showTeam.res}}</text></view>
        </view>
      </view>
      <view class="modal-section"><text class="modal-sectitle">车队简介</text><text class="modal-desc">{{showTeam.detail}}</text></view>
    </view>
  </view>

</scroll-view>
