<view class="page">
  <view class="nav-bar"><text class="nav-title">发现</text></view>
  <view class="team-card" wx:for="{{teams}}" wx:key="name">
    <view class="tc-header">
      <text class="tch-icon">{{item.icon}}</text>
      <view class="tch-info"><text class="tch-name">{{item.name}}</text><text class="tch-base">📍 {{item.base}}</text></view>
    </view>
    <text class="tc-desc">{{item.desc}}</text>
    <view class="tc-stats">
      <view class="tcs-item"><text class="tcs-val">{{item.championships}}</text><text class="tcs-lbl">车队冠军</text></view>
      <view class="tcs-item"><text class="tcs-val">{{item.wins}}</text><text class="tcs-lbl">分站冠军</text></view>
      <view class="tcs-item"><text class="tcs-val">{{item.since}}</text><text class="tcs-lbl">参赛</text></view>
    </view>
  </view>
</view>
