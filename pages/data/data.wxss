.page { padding: 0 32rpx 120rpx; }
.nav-bar { display: flex; justify-content: space-between; align-items: center; height: 88rpx; }
.nav-title { font-size: 36rpx; font-weight: 600; color: #333; }
.tabs { display: flex; gap: 0; margin-bottom: 16rpx; background: #fff; border-radius: 8rpx; padding: 4rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 24rpx; color: #999; font-weight: 600; border-radius: 6rpx; }
.tab.active { background: #F5F5F5; color: #E10600; }
.ds-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #F0F0F0; gap: 16rpx; }
.ds-pos { width: 32rpx; font-size: 28rpx; font-weight: 600; color: #999; text-align: center; }
.ds-row:nth-child(1) .ds-pos,.ds-row:nth-child(2) .ds-pos,.ds-row:nth-child(3) .ds-pos { color: #FFC107; }
.ds-info { flex: 1; }
.ds-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.ds-team { font-size: 20rpx; color: #999; display: block; }
.ds-pts { font-size: 28rpx; font-weight: 600; color: #333; }

.team-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.tc-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.tch-icon { font-size: 48rpx; }
.tch-info { flex: 1; }
.tch-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tch-base { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }
.tc-desc { font-size: 24rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 16rpx; }
.tc-stats { display: flex; gap: 16rpx; }
.tcs-item { flex: 1; text-align: center; background: #F5F5F5; border-radius: 8rpx; padding: 16rpx 8rpx; }
.tcs-val { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tcs-lbl { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
