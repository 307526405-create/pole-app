page { height: 100vh; overflow: hidden; }
.nav-bar { height: 88rpx; display: flex; align-items: center; padding: 0 32rpx; }
.nav-title { font-size: 36rpx; font-weight: 600; color: #333; }
.tabs-fixed { display: flex; margin: 0 32rpx 16rpx; background: #fff; border-radius: 8rpx; padding: 4rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 24rpx; color: #999; font-weight: 600; border-radius: 6rpx; }
.tab.active { background: #F5F5F5; color: #E10600; }
.content-scroll { height: calc(100vh - 176rpx); padding: 0 32rpx; box-sizing: border-box; }

.sub-tabs { display: flex; gap: 0; margin-bottom: 16rpx; background: #F5F5F5; border-radius: 6rpx; padding: 4rpx; }
.sub-tab { flex: 1; text-align: center; padding: 12rpx 0; font-size: 22rpx; color: #999; font-weight: 600; border-radius: 4rpx; }
.sub-tab.active { background: #fff; color: #E10600; }

.cal-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #F0F0F0; gap: 8rpx; }
.cal-num { width: 40rpx; font-size: 24rpx; color: #999; font-weight: 600; text-align: center; flex-shrink: 0; }
.cal-flag { font-size: 36rpx; width: 48rpx; text-align: center; flex-shrink: 0; }
.cal-info { flex: 1; min-width: 0; }
.cal-gp { font-size: 28rpx; font-weight: 600; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cal-detail { font-size: 20rpx; color: #999; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cal-tag { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 8rpx; font-weight: 600; flex-shrink: 0; }
.cal-tag.done { background: #F5F5F5; color: #999; }
.cal-tag.now { background: #E10600; color: #fff; }
.cal-tag.next { background: rgba(225,6,0,0.06); color: #E10600; }
.cal-tag.tbd { background: #FFF3CD; color: #856404; }

.ds-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; gap: 12rpx; }
.ds-pos { width: 36rpx; font-size: 28rpx; font-weight: 600; color: #999; text-align: center; flex-shrink: 0; }
.ds-row:nth-child(1) .ds-pos,.ds-row:nth-child(2) .ds-pos,.ds-row:nth-child(3) .ds-pos { color: #FFC107; }
.ds-img { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; }
.ds-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 18rpx; font-weight: 700; color: #fff; }
.ds-info { flex: 1; min-width: 0; }
.ds-name { font-size: 28rpx; font-weight: 600; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ds-en { font-size: 20rpx; color: #999; }
.ds-pts { font-size: 28rpx; font-weight: 600; color: #333; flex-shrink: 0; }

.team-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.tc-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.tch-logo { width: 64rpx; height: 64rpx; border-radius: 16rpx; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 800; color: #fff; }
.tch-icon { font-size: 48rpx; }
.tch-info { flex: 1; }
.tch-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tch-base { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }
.tc-desc { font-size: 24rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 16rpx; }
.tc-drivers { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.tcd-item { flex: 1; background: #F5F5F5; border-radius: 8rpx; padding: 12rpx 8rpx; text-align: center; }
.tcd-label { font-size: 18rpx; color: #999; display: block; margin-bottom: 4rpx; }
.tcd-name { font-size: 22rpx; font-weight: 600; color: #333; display: block; }
.tc-stats { display: flex; gap: 16rpx; }
.tcs-item { flex: 1; text-align: center; background: #F5F5F5; border-radius: 8rpx; padding: 16rpx 8rpx; }
.tcs-val { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tcs-lbl { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.circuit-map { width: 100%; margin-bottom: 16rpx; border-radius: 8rpx; }
